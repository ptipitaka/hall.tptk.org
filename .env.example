# Copy to .env and fill in — never commit .env

# Django
SECRET_KEY=change-me-in-local-env
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=hall.settings.dev
WAGTAILADMIN_BASE_URL=http://localhost:8000

# Database (docker compose)
POSTGRES_DB=hall
POSTGRES_USER=hall
POSTGRES_PASSWORD=hall
DATABASE_URL=postgres://hall:hall@db:5432/hall

# Media — dev uses local files (Phase 1–5)
USE_SPACES=False

# DigitalOcean Spaces — only when testing Spaces or production (Phase 6)
# Store real values in .env locally or GitHub Secrets — never commit
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=sacred
AWS_S3_ENDPOINT_URL=https://sgp1.digitaloceanspaces.com
